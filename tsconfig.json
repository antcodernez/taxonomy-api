{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",         // 👈 aquí cambiamos a es2020
    "moduleResolution": "node", // 👈 necesario para que reconozca módulos en node_modules
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
